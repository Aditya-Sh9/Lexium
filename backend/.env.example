APP_NAME=LegalConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── MongoDB Connection ───────────────────────────────────────────────
DB_CONNECTION=mongodb
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/
MONGODB_DATABASE=legalconnect

# ─── Firebase (Backend Token Verification) ────────────────────────────
# Download your service account JSON from:
#   Firebase Console → Project Settings → Service Accounts → Generate New Private Key
#
# LOCAL: Save it as firebase_credentials.json in the backend/ root folder.
FIREBASE_CREDENTIALS=firebase_credentials.json
#
# PRODUCTION (Render): Base64-encode the JSON file and set this env var.
#   On Linux/Mac: base64 -w 0 firebase_credentials.json
#   On Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase_credentials.json"))
# FIREBASE_CREDENTIALS_JSON=

# Set to false once Firebase is fully configured
MOCK_AUTH=false

# ─── Session / Cache / Queue (file-based, no SQL dependency) ──────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
